@page "/admin/users"
@using Titan.Client.Services.Apibase
@using Titan.Client.Services.AppServices
@using Titan.Client.Services.Models
@inject UserService  UserSvc
@inject ToastService Toast
@inject AuthService  Auth
@inject NavigationManager Nav

<PageTitle>Users — Admin TITAN</PageTitle>
@if (!Auth.IsAdmin) { Nav.NavigateTo("/"); return; }

<div class="main-content" style="padding-top:90px">
  <div style="display:flex">
    <AdminSidebar Active="users" />
    <div style="flex:1;padding:36px;min-width:0">

      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;flex-wrap:wrap;gap:14px">
        <div><h1 style="font-size:2rem;margin-bottom:4px">Users</h1><p style="color:var(--silver-dim)">@_total registered users</p></div>
        <div style="display:flex;gap:10px">
          <input type="text" class="form-control" placeholder="Search…" @bind="_search" @bind:event="oninput" style="width:210px"/>
          <button class="btn btn-outline-gold btn-sm" @onclick="Load"><i class="fas fa-search"></i></button>
        </div>
      </div>

      @if (_loading)
      { <div style="text-align:center;padding:60px"><i class="fas fa-spinner fa-spin" style="font-size:2rem;color:var(--gold)"></i></div> }
      else
      {
        <div class="card" style="padding:0;overflow:hidden">
          <table class="t-admin">
            <thead><tr><th>User</th><th>Role</th><th>Status</th><th>Joined</th><th>Last Login</th><th>Actions</th></tr></thead>
            <tbody>
              @foreach (var u in _users)
              {
                <tr>
                  <td>
                    <div style="display:flex;align-items:center;gap:10px">
                      @if (!string.IsNullOrEmpty(u.ProfileImageUrl))
                      { <img src="@u.ProfileImageUrl" style="width:34px;height:34px;border-radius:50%;object-fit:cover"/> }
                      else
                      { <div style="width:34px;height:34px;border-radius:50%;background:rgba(212,175,55,.1);display:flex;align-items:center;justify-content:center;color:var(--gold);font-size:.82rem"><i class="fas fa-user"></i></div> }
                      <div>
                        <p style="color:var(--white);font-size:.87rem;font-weight:600">@u.FullName</p>
                        <p style="color:var(--silver-dim);font-size:.73rem">@u.Email</p>
                      </div>
                    </div>
                  </td>
                  <td><span class="badge @(u.Role=="Admin"?"badge-gold":"badge-silver")">@u.Role</span></td>
                  <td>
                    @if (u.IsBanned) { <span class="badge badge-danger">Banned</span> }
                    else if (u.IsActive) { <span class="badge badge-success">Active</span> }
                    else { <span class="badge badge-warning">Inactive</span> }
                  </td>
                  <td style="color:var(--silver-dim);font-size:.78rem">@u.CreatedAt.ToString("MMM dd, yyyy")</td>
                  <td style="color:var(--silver-dim);font-size:.78rem">@(u.LastLoginAt?.ToString("MMM dd")??"-")</td>
                  <td>
                    @if (u.Role != "Admin")
                    {
                      <div style="display:flex;gap:7px">
                        @if (!u.IsBanned)
                        { <button class="btn btn-danger btn-sm" @onclick="() => StartBan(u)" title="Ban"><i class="fas fa-ban"></i></button> }
                        else
                        { <button class="btn btn-outline-gold btn-sm" @onclick="()=>Unban(u)" title="Unban"><i class="fas fa-unlock"></i></button> }
                        <button class="btn btn-danger btn-sm" @onclick="()=>_delTarget=u" title="Delete"><i class="fas fa-trash"></i></button>
                      </div>
                    }
                  </td>
                </tr>
              }
            </tbody>
          </table>
          @if (!_users.Any())
          { <div style="text-align:center;padding:60px;color:var(--silver-dim)"><i class="fas fa-users" style="font-size:2rem;opacity:.2;margin-bottom:12px;display:block"></i>No users found</div> }
        </div>

        @if (_totalPages > 1)
        {
          <div style="display:flex;gap:7px;justify-content:center;margin-top:24px">
            @for(int i=1;i<=_totalPages;i++){var pg=i;<button class="page-btn @(_page==pg?"active":"")" @onclick="()=>GoPage(pg)">@pg</button>}
          </div>
        }
      }
    </div>
  </div>
</div>

<!-- BAN MODAL -->
@if (_showBan && _banTarget is not null)
{
  <div class="modal-bg">
    <div class="card modal-box" style="max-width:420px">
      <h3 style="margin-bottom:16px">Ban @_banTarget.FullName</h3>
      <div class="form-group">
        <label class="form-label">Reason *</label>
        <textarea class="form-control" rows="3" @bind="_banReason" placeholder="Reason for ban…"></textarea>
      </div>
      <div style="display:flex;gap:10px;justify-content:flex-end">
        <button class="btn btn-outline-silver" @onclick="CancelBan">Cancel</button>
        <button class="btn btn-danger" @onclick="BanUser"><i class="fas fa-ban"></i> Ban User</button>
      </div>
    </div>
  </div>
}

<!-- DELETE CONFIRM -->
@if (_delTarget is not null)
{
  <div class="modal-bg">
    <div class="card modal-box" style="max-width:380px;text-align:center">
      <i class="fas fa-exclamation-triangle" style="font-size:2.5rem;color:var(--danger);margin-bottom:14px;display:block"></i>
      <h3 style="margin-bottom:8px">Delete @_delTarget.FullName?</h3>
      <p style="color:var(--silver-dim);margin-bottom:22px">This action is permanent.</p>
      <div style="display:flex;gap:10px;justify-content:center">
        <button class="btn btn-outline-silver" @onclick="()=>_delTarget=null">Cancel</button>
        <button class="btn btn-danger" @onclick="DeleteUser"><i class="fas fa-trash"></i> Delete</button>
      </div>
    </div>
  </div>
}

@code {
  List<UserDto> _users=new(); bool _loading=true,_showBan;
  string _search="",_banReason=""; int _page=1,_totalPages=1,_total;
  UserDto? _banTarget,_delTarget;

  void StartBan(UserDto u) { _banTarget = u; _showBan = true; }
  void CancelBan() { _showBan = false; _banReason = ""; }

  protected override async Task OnInitializedAsync(){if(!Auth.IsAdmin)return;await Load();}

  async Task Load()
  {
    _loading=true;
    var r=await UserSvc.GetAllAsync(_page,20,_search);
    _users=r?.Items??new();_total=r?.TotalCount??0;_totalPages=r?.TotalPages??1;
    _loading=false;
  }

  async Task GoPage(int p){_page=p;await Load();}

  async Task BanUser()
  {
    if(_banTarget is null||string.IsNullOrWhiteSpace(_banReason))return;
    if(await UserSvc.BanAsync(_banTarget.Id,_banReason)){Toast.Success($"{_banTarget.FullName} banned.");_showBan=false;_banReason="";await Load();}
    else Toast.Error("Failed.");
  }

  async Task Unban(UserDto u)
  {
    if(await UserSvc.UnbanAsync(u.Id)){Toast.Success($"{u.FullName} unbanned.");await Load();}
    else Toast.Error("Failed.");
  }

  async Task DeleteUser()
  {
    if(_delTarget is null) return;
    if(await UserSvc.DeleteAsync(_delTarget.Id)){Toast.Success("User deleted.");_delTarget=null;await Load();}
    else{Toast.Error("Failed.");_delTarget=null;}
  }
}
