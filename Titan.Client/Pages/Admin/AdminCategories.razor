@page "/admin/categories"
@using Titan.Client.Services.Apibase
@using Titan.Client.Services.AppServices
@using Titan.Client.Services.Models
@inject CategoryService CatSvc
@inject ToastService    Toast
@inject AuthService     Auth
@inject NavigationManager Nav

<PageTitle>Categories — Admin TITAN</PageTitle>
@if (!Auth.IsAdmin) { Nav.NavigateTo("/"); return; }

<div class="main-content" style="padding-top:90px">
  <div style="display:flex">
    <AdminSidebar Active="categories" />
    <div style="flex:1;padding:36px;min-width:0">

      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px">
        <h1 style="font-size:2rem">Categories</h1>
        <button class="btn btn-gold" @onclick="OpenCreate"><i class="fas fa-plus"></i> Add Category</button>
      </div>

      <div class="card" style="padding:0;overflow:hidden">
        <table class="t-admin">
          <thead><tr><th>Category</th><th>Slug</th><th>Products</th><th>Order</th><th>Actions</th></tr></thead>
          <tbody>
            @foreach (var c in CatSvc.All)
            {
              <tr>
                <td>
                  <div style="display:flex;align-items:center;gap:11px">
                    @if (!string.IsNullOrEmpty(c.ImageUrl))
                    { <img src="@c.ImageUrl" style="width:38px;height:38px;object-fit:cover;border-radius:5px"/> }
                    <div>
                      <p style="color:var(--white);font-weight:600;font-size:.87rem">@c.Name</p>
                      <p style="color:var(--silver-dim);font-size:.73rem">@c.NameAr</p>
                    </div>
                  </div>
                </td>
                <td style="color:var(--silver-dim);font-size:.82rem;font-family:monospace">@c.Slug</td>
                <td style="color:var(--silver)">@c.ProductCount</td>
                <td style="color:var(--silver)">@c.DisplayOrder</td>
                <td>
                  <div style="display:flex;gap:7px">
                    <button class="btn btn-outline-gold btn-sm" @onclick="()=>OpenEdit(c)"><i class="fas fa-edit"></i></button>
                    <button class="btn btn-danger btn-sm" @onclick="()=>_delTarget=c"><i class="fas fa-trash"></i></button>
                  </div>
                </td>
              </tr>
            }
          </tbody>
        </table>
        @if (!CatSvc.All.Any())
        { <div style="text-align:center;padding:60px;color:var(--silver-dim)"><i class="fas fa-tags" style="font-size:2rem;opacity:.2;margin-bottom:12px;display:block"></i>No categories yet</div> }
      </div>
    </div>
  </div>
</div>

<!-- MODAL -->
@if (_showModal)
{
  <div class="modal-bg" @onclick="()=>_showModal=false">
    <div class="card modal-box" style="max-width:500px" @onclick:stopPropagation>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:22px">
        <h3>@(_editId.HasValue?"Edit Category":"Add Category")</h3>
        <button @onclick="()=>_showModal=false" style="background:none;border:none;color:var(--silver);cursor:pointer;font-size:1.1rem"><i class="fas fa-times"></i></button>
      </div>

      <div class="grid grid-2" style="gap:14px">
        <div class="form-group"><label class="form-label">Name (EN) *</label><input class="form-control" @bind="_cName"/></div>
        <div class="form-group"><label class="form-label">Name (AR)</label><input class="form-control" @bind="_cNameAr" dir="rtl"/></div>
      </div>
      <div class="form-group"><label class="form-label">Slug *</label><input class="form-control" @bind="_cSlug" placeholder="men-clothing"/></div>
      <div class="form-group"><label class="form-label">Description</label><textarea class="form-control" rows="2" @bind="_cDesc"></textarea></div>
      <div class="form-group"><label class="form-label">Image URL</label><input class="form-control" @bind="_cImg" placeholder="https://…"/></div>
      <div class="grid grid-2" style="gap:14px">
        <div class="form-group"><label class="form-label">Display Order</label><input type="number" class="form-control" @bind="_cOrder"/></div>
        <div class="form-group"><label class="form-label">Parent</label>
          <select class="form-control" @bind="_cParent">
            <option value="">None (Top Level)</option>
            @foreach (var c in CatSvc.All.Where(x=>!_editId.HasValue||x.Id!=_editId))
            { <option value="@c.Id">@c.Name</option> }
          </select>
        </div>
      </div>

      @if (!string.IsNullOrEmpty(_mErr))
      { <div style="background:rgba(229,62,62,.1);border:1px solid var(--danger);border-radius:var(--r);padding:11px 14px;margin-bottom:14px;color:#FC8181;font-size:.85rem">@_mErr</div> }

      <div style="display:flex;gap:10px;justify-content:flex-end">
        <button class="btn btn-outline-silver" @onclick="()=>_showModal=false">Cancel</button>
        <button class="btn btn-gold" @onclick="Save" disabled="@_saving">
          @if(_saving){<i class="fas fa-spinner fa-spin"></i>}else{<i class="fas fa-save"></i>} Save
        </button>
      </div>
    </div>
  </div>
}

<!-- DELETE CONFIRM -->
@if (_delTarget is not null)
{
  <div class="modal-bg">
    <div class="card modal-box" style="max-width:360px;text-align:center">
      <i class="fas fa-exclamation-triangle" style="font-size:2.5rem;color:var(--danger);margin-bottom:14px;display:block"></i>
      <h3 style="margin-bottom:8px">Delete "@_delTarget.Name"?</h3>
      <p style="color:var(--silver-dim);margin-bottom:22px">Categories with products cannot be deleted.</p>
      <div style="display:flex;gap:10px;justify-content:center">
        <button class="btn btn-outline-silver" @onclick="()=>_delTarget=null">Cancel</button>
        <button class="btn btn-danger" @onclick="Delete"><i class="fas fa-trash"></i> Delete</button>
      </div>
    </div>
  </div>
}

<style>
  .t-admin{width:100%;border-collapse:collapse}
  .t-admin th{padding:11px 15px;text-align:left;font-size:.72rem;letter-spacing:2px;text-transform:uppercase;color:var(--silver-dim);border-bottom:1px solid var(--black-border);font-weight:600}
  .t-admin td{padding:14px 15px;border-bottom:1px solid rgba(34,34,34,.5);font-size:.88rem;color:var(--silver)}
  .t-admin tr:hover td{background:rgba(255,255,255,.015)}
  .modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:2000;display:flex;align-items:center;justify-content:center;padding:24px}
  .modal-box{width:100%;max-width:620px;max-height:90vh;overflow-y:auto}
</style>

@code {
  bool _showModal,_saving; string _mErr=""; Guid? _editId; CategoryDto? _delTarget;
  string _cName="",_cNameAr="",_cSlug="",_cDesc="",_cImg="",_cParent=""; int _cOrder;

  protected override async Task OnInitializedAsync(){if(!Auth.IsAdmin)return;await CatSvc.LoadAsync();}

  void OpenCreate(){_editId=null;_cName=_cNameAr=_cSlug=_cDesc=_cImg=_cParent="";_cOrder=0;_mErr="";_showModal=true;}

  void OpenEdit(CategoryDto c)
  { _editId=c.Id;_cName=c.Name;_cNameAr=c.NameAr;_cSlug=c.Slug;_cDesc=c.Description??"";_cImg=c.ImageUrl??"";_cOrder=c.DisplayOrder;_cParent=c.ParentId?.ToString()??"";_mErr="";_showModal=true; }

  async Task Save()
  {
    if(string.IsNullOrWhiteSpace(_cName)||string.IsNullOrWhiteSpace(_cSlug)){_mErr="Name and Slug required.";return;}
    _saving=true;
    Guid? parentGuid=string.IsNullOrEmpty(_cParent)?null:Guid.Parse(_cParent);
    if(_editId.HasValue)
    {
      var r=await CatSvc.UpdateAsync(_editId.Value,new{name=_cName,nameAr=_cNameAr,description=_cDesc,imageUrl=_cImg,isActive=true,displayOrder=_cOrder});
      if(r?.Success==true){Toast.Success("Category updated!");_showModal=false;await CatSvc.LoadAsync();}else _mErr=r?.Message??"Failed.";
    }
    else
    {
      var r=await CatSvc.CreateAsync(new{name=_cName,nameAr=_cNameAr,slug=_cSlug,description=_cDesc,imageUrl=_cImg,parentId=parentGuid,displayOrder=_cOrder});
      if(r?.Success==true){Toast.Success("Category created!");_showModal=false;await CatSvc.LoadAsync();}else _mErr=r?.Message??"Failed.";
    }
    _saving=false;
  }

  async Task Delete()
  {
    if(_delTarget is null) return;
    if(await CatSvc.DeleteAsync(_delTarget.Id)){Toast.Success("Deleted.");_delTarget=null;await CatSvc.LoadAsync();}
    else{Toast.Error("Cannot delete — category may have products.");_delTarget=null;}
  }
}
