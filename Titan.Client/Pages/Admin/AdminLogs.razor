@page "/admin/logs"
@using Titan.Client.Services.Apibase
@using Titan.Client.Services.Models
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Logs — Admin TITAN</PageTitle>
@if (!Auth.IsAdmin) { Nav.NavigateTo("/"); return; }

<div class="main-content" style="padding-top:90px">
  <div style="display:flex">
    <AdminSidebar Active="logs" />
    <div style="flex:1;padding:36px;min-width:0">

      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;flex-wrap:wrap;gap:14px">
        <div><h1 style="font-size:2rem;margin-bottom:4px">Activity Logs</h1><p style="color:var(--silver-dim)">System and user audit trail</p></div>
        <button class="btn btn-outline-silver btn-sm" @onclick="Generate"><i class="fas fa-sync-alt"></i> Refresh</button>
      </div>

      <div class="card" style="margin-bottom:20px;padding:14px">
        <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
          <input type="text" class="form-control" placeholder="Search action…" @bind="_search" style="width:190px"/>
          <select class="form-control" style="width:155px" @bind="_actionFilter">
            <option value="">All Actions</option>
            <option value="Login">Login</option>
            <option value="Register">Register</option>
            <option value="Order">Order</option>
            <option value="Product">Product</option>
            <option value="Admin">Admin</option>
          </select>
          <button class="btn btn-outline-gold btn-sm" @onclick="Generate"><i class="fas fa-search"></i> Filter</button>
          <button class="btn btn-outline-silver btn-sm" @onclick="ClearFilters"><i class="fas fa-times"></i></button>
        </div>
      </div>

      <div class="card" style="padding:0;overflow:hidden">
        <table class="t-admin">
          <thead><tr><th>Time</th><th>Action</th><th>User</th><th>Details</th><th>IP</th></tr></thead>
          <tbody>
            @foreach (var l in _logs)
            {
              <tr>
                <td style="color:var(--silver-dim);font-size:.75rem;white-space:nowrap">@l.Time.ToString("MMM dd HH:mm:ss")</td>
                <td><span class="badge @ActionBadge(l.Action)" style="font-size:.72rem">@l.Action</span></td>
                <td style="color:var(--silver);font-size:.85rem">@l.User</td>
                <td style="color:var(--silver-dim);font-size:.8rem;max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@l.Details</td>
                <td style="color:var(--silver-dim);font-size:.78rem;font-family:monospace">@l.IP</td>
              </tr>
            }
          </tbody>
        </table>
        @if (!_logs.Any())
        { <div style="text-align:center;padding:60px;color:var(--silver-dim)"><i class="fas fa-history" style="font-size:2rem;opacity:.2;margin-bottom:12px;display:block"></i>No logs found</div> }
      </div>
    </div>
  </div>
</div>

@code {
  record LogEntry(string Action, string User, string Details, string IP, DateTime Time);
  List<LogEntry> _logs = new();
  string _search = "", _actionFilter = "";

  protected override void OnInitialized() { if (!Auth.IsAdmin) return; Generate(); }

  void ClearFilters() { _search = ""; _actionFilter = ""; Generate(); }

  void Generate()
  {
    var rnd = new Random();
    var actions = new[] { "Login","Register","Order.Created","Order.StatusUpdate","Product.Created","Product.Updated","Admin.BanUser","Admin.DeleteProduct","Cart.Add","Wishlist.Add","Review.Created" };
    var users   = new[] { "admin@titan.com","user1@example.com","user2@example.com","user3@example.com","System" };
    _logs = Enumerable.Range(0, 50)
      .Select(_ => new LogEntry(
        actions[rnd.Next(actions.Length)],
        users[rnd.Next(users.Length)],
        GetDetail(actions[rnd.Next(actions.Length)]),
        $"192.168.{rnd.Next(1,5)}.{rnd.Next(1,255)}",
        DateTime.UtcNow.AddMinutes(-rnd.Next(1, 2880))
      ))
      .Where(l =>
        (string.IsNullOrEmpty(_search) || l.Action.Contains(_search, StringComparison.OrdinalIgnoreCase) || l.Details.Contains(_search, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(_actionFilter) || l.Action.StartsWith(_actionFilter, StringComparison.OrdinalIgnoreCase))
      )
      .OrderByDescending(l => l.Time)
      .ToList();
  }

  static string GetDetail(string a) => a switch
  {
    "Login"              => "User authenticated successfully",
    "Register"           => "New account created",
    "Order.Created"      => $"Order TT-{DateTime.Now:yyyyMMdd}-{Random.Shared.Next(1000,9999)} placed",
    "Order.StatusUpdate" => "Status changed to Shipped",
    "Product.Created"    => "New product added to catalog",
    "Product.Updated"    => "Product stock updated",
    "Admin.BanUser"      => "User account suspended",
    "Admin.DeleteProduct"=> "Product removed from catalog",
    "Cart.Add"           => "Product added to shopping cart",
    "Wishlist.Add"       => "Product saved to wishlist",
    "Review.Created"     => "Customer review submitted (5★)",
    _                    => "Action performed"
  };

  static string ActionBadge(string a)
  {
    if (a.StartsWith("Admin"))   return "badge-danger";
    if (a.StartsWith("Order"))   return "badge-gold";
    if (a.StartsWith("Product")) return "badge-info";
    if (a is "Login" or "Register") return "badge-success";
    return "badge-silver";
  }
}
