@page "/admin/products"
@using Titan.Client.Services.Apibase
@using Titan.Client.Services.AppServices
@using Titan.Client.Services.Models
@inject ProductService  ProductSvc
@inject CategoryService CatSvc
@inject ToastService    Toast
@inject AuthService     Auth
@inject NavigationManager Nav

<PageTitle>Products — Admin TITAN</PageTitle>
@if (!Auth.IsAdmin) { Nav.NavigateTo("/"); return; }

<div class="main-content" style="padding-top:90px">
  <div style="display:flex">
    <AdminSidebar Active="products" />
    <div style="flex:1;padding:36px;min-width:0">

      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:28px;flex-wrap:wrap;gap:14px">
        <div><h1 style="font-size:2rem;margin-bottom:4px">Products</h1><p style="color:var(--silver-dim)">@_total products total</p></div>
        <button class="btn btn-gold" @onclick="OpenCreate"><i class="fas fa-plus"></i> Add Product</button>
      </div>

      <!-- FILTERS -->
      <div class="card" style="margin-bottom:20px;padding:14px">
        <div style="display:flex;gap:10px;flex-wrap:wrap;align-items:center">
          <input type="text" class="form-control" placeholder="Search…" @bind="_search" @bind:event="oninput" style="width:200px" />
          <select class="form-control" style="width:170px" @onchange="e => { _catF=e.Value?.ToString(); _ = Load(); }">
            <option value="">All Categories</option>
            @foreach (var c in CatSvc.All) { <option value="@c.Id">@c.Name</option> }
          </select>
          <button class="btn btn-outline-gold btn-sm" @onclick="Load"><i class="fas fa-search"></i></button>
          <button class="btn btn-outline-silver btn-sm" @onclick="() => { _search=\"\"; _catF=\"\"; _ = Load(); }"><i class="fas fa-times"></i> Clear</button>
        </div>
      </div>

      @if (_loading)
      { <div style="text-align:center;padding:60px"><i class="fas fa-spinner fa-spin" style="font-size:2rem;color:var(--gold)"></i></div> }
      else
      {
        <div class="card" style="padding:0;overflow:hidden">
          <table class="t-titan">
            <thead><tr><th>Product</th><th>Category</th><th>Price</th><th>Stock</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
              @foreach (var p in _products)
              {
                <tr>
                  <td>
                    <div style="display:flex;align-items:center;gap:11px">
                      <img src="@p.MainImageUrl" style="width:42px;height:54px;object-fit:cover;border-radius:4px;border:1px solid var(--black-border)" />
                      <div>
                        <p style="color:var(--white);font-weight:600;font-size:.87rem">@p.Name</p>
                        <p style="color:var(--silver-dim);font-size:.73rem">@p.SKU</p>
                      </div>
                    </div>
                  </td>
                  <td><span class="badge badge-silver">@p.Category?.Name</span></td>
                  <td>
                    <span style="color:var(--gold);font-weight:700">$@p.CurrentPrice.ToString("F2")</span>
                    @if(p.HasDiscount){<br/><span style="color:var(--silver-dim);text-decoration:line-through;font-size:.75rem">$@p.Price.ToString("F2")</span>}
                  </td>
                  <td><span class="badge @(p.StockQuantity==0?"badge-danger":p.StockQuantity<10?"badge-warning":"badge-success")">@p.StockQuantity</span></td>
                  <td><span class="badge @(p.IsActive?"badge-success":"badge-danger")">@(p.IsActive?"Active":"Inactive")</span></td>
                  <td>
                    <div style="display:flex;gap:7px">
                      <button class="btn btn-outline-gold btn-sm" @onclick="() => OpenEdit(p)"><i class="fas fa-edit"></i></button>
                      <a href="/product/@p.Slug" target="_blank" class="btn btn-outline-silver btn-sm"><i class="fas fa-eye"></i></a>
                      <button class="btn btn-danger btn-sm" @onclick="() => _delTarget=p"><i class="fas fa-trash"></i></button>
                    </div>
                  </td>
                </tr>
              }
            </tbody>
          </table>
          @if (!_products.Any())
          {
            <div style="text-align:center;padding:60px;color:var(--silver-dim)"><i class="fas fa-box-open" style="font-size:2rem;opacity:.2;margin-bottom:12px;display:block"></i>No products found</div>
          }
        </div>

        @if (_totalPages > 1)
        {
          <div style="display:flex;gap:7px;justify-content:center;margin-top:24px">
            @for(int i=1;i<=_totalPages;i++){var pg=i;<button class="page-btn @(_page==pg?"active":"")" @onclick="()=>GoPage(pg)">@pg</button>}
          </div>
        }
      }
    </div>
  </div>
</div>

<!-- PRODUCT MODAL -->
@if (_showModal)
{
  <div class="modal-overlay" @onclick="() => _showModal=false">
    <div class="card modal-box" @onclick:stopPropagation>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:22px">
        <h3>@(_editId.HasValue?"Edit Product":"Add Product")</h3>
        <button @onclick="() => _showModal=false" style="background:none;border:none;color:var(--silver);cursor:pointer;font-size:1.1rem"><i class="fas fa-times"></i></button>
      </div>

      <div class="grid grid-2" style="gap:14px">
        <div class="form-group"><label class="form-label">Name (EN) *</label><input class="form-control" @bind="_pName"/></div>
        <div class="form-group"><label class="form-label">Name (AR)</label><input class="form-control" @bind="_pNameAr" dir="rtl"/></div>
      </div>
      <div class="form-group"><label class="form-label">Description</label><textarea class="form-control" rows="2" @bind="_pDesc"></textarea></div>
      <div class="grid grid-2" style="gap:14px">
        <div class="form-group"><label class="form-label">Slug *</label><input class="form-control" @bind="_pSlug"/></div>
        <div class="form-group"><label class="form-label">SKU *</label><input class="form-control" @bind="_pSku"/></div>
      </div>
      <div class="grid grid-2" style="gap:14px">
        <div class="form-group"><label class="form-label">Price *</label><input type="number" class="form-control" @bind="_pPrice" step="0.01"/></div>
        <div class="form-group"><label class="form-label">Discount Price</label><input type="number" class="form-control" @bind="_pDiscount" step="0.01"/></div>
      </div>
      <div class="grid grid-2" style="gap:14px">
        <div class="form-group"><label class="form-label">Stock *</label><input type="number" class="form-control" @bind="_pStock"/></div>
        <div class="form-group"><label class="form-label">Category *</label>
          <select class="form-control" @bind="_pCatId">
            <option value="">Select…</option>
            @foreach(var c in CatSvc.All){<option value="@c.Id">@c.Name</option>}
          </select>
        </div>
      </div>
      <div class="form-group"><label class="form-label">Main Image URL *</label><input class="form-control" @bind="_pMainImg" placeholder="https://…"/></div>
      <div class="form-group"><label class="form-label">Extra Images (one per line)</label><textarea class="form-control" rows="3" @bind="_pImgs" placeholder="https://img1.jpg&#10;https://img2.jpg"></textarea></div>

      <div style="display:flex;gap:14px;align-items:center;margin-bottom:18px">
        <label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:.85rem"><input type="checkbox" @bind="_pFeatured" style="accent-color:var(--gold)"/> Featured</label>
        @if(_editId.HasValue){<label style="display:flex;align-items:center;gap:7px;cursor:pointer;font-size:.85rem"><input type="checkbox" @bind="_pActive" style="accent-color:var(--gold)"/> Active</label>}
      </div>

      @if(!string.IsNullOrEmpty(_mErr)){<div style="background:rgba(229,62,62,.1);border:1px solid var(--danger);border-radius:var(--r);padding:11px 14px;margin-bottom:14px;color:#FC8181;font-size:.85rem">@_mErr</div>}

      <div style="display:flex;gap:10px;justify-content:flex-end">
        <button class="btn btn-outline-silver" @onclick="() => _showModal=false">Cancel</button>
        <button class="btn btn-gold" @onclick="Save" disabled="@_saving">
          @if(_saving){<i class="fas fa-spinner fa-spin"></i>}else{<i class="fas fa-save"></i>}
          @(_editId.HasValue?"Save Changes":"Create Product")
        </button>
      </div>
    </div>
  </div>
}

<!-- DELETE CONFIRM -->
@if (_delTarget is not null)
{
  <div class="modal-overlay">
    <div class="card modal-box" style="max-width:380px;text-align:center">
      <i class="fas fa-exclamation-triangle" style="font-size:2.5rem;color:var(--danger);margin-bottom:14px;display:block"></i>
      <h3 style="margin-bottom:8px">Delete Product?</h3>
      <p style="color:var(--silver-dim);margin-bottom:22px">This cannot be undone.</p>
      <div style="display:flex;gap:10px;justify-content:center">
        <button class="btn btn-outline-silver" @onclick="() => _delTarget=null">Cancel</button>
        <button class="btn btn-danger" @onclick="Delete"><i class="fas fa-trash"></i> Delete</button>
      </div>
    </div>
  </div>
}

<style>
  .t-titan{width:100%;border-collapse:collapse}
  .t-titan th{padding:11px 15px;text-align:left;font-size:.72rem;letter-spacing:2px;text-transform:uppercase;color:var(--silver-dim);border-bottom:1px solid var(--black-border);font-weight:600}
  .t-titan td{padding:14px 15px;border-bottom:1px solid rgba(34,34,34,.5);font-size:.88rem;color:var(--silver)}
  .t-titan tr:hover td{background:rgba(255,255,255,.015)}
  .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:2000;display:flex;align-items:center;justify-content:center;padding:24px}
  .modal-box{width:100%;max-width:660px;max-height:90vh;overflow-y:auto}
  .page-btn{width:38px;height:38px;border-radius:var(--r);border:1px solid var(--black-border);background:var(--black-card);color:var(--silver);cursor:pointer;transition:var(--tr);display:flex;align-items:center;justify-content:center;font-size:.85rem}
  .page-btn:hover,.page-btn.active{border-color:var(--gold);color:var(--gold);background:rgba(212,175,55,.08)}
</style>

@code {
  List<ProductDto> _products=new(); bool _loading=true,_showModal,_saving;
  string _search="",_catF="",_mErr=""; int _page=1,_totalPages=1,_total;
  Guid? _editId; ProductDto? _delTarget;

  string _pName="",_pNameAr="",_pDesc="",_pSlug="",_pSku="",_pMainImg="",_pImgs="";
  decimal _pPrice,_pDiscount; int _pStock; string _pCatId="";
  bool _pFeatured,_pActive=true;

  protected override async Task OnInitializedAsync()
  {
    if(!Auth.IsAdmin) return;
    await CatSvc.LoadAsync(); await Load();
  }

  async Task Load()
  {
    _loading=true;
    var f=new ProductFilter{Search=_search,CategoryId=!string.IsNullOrEmpty(_catF)?Guid.Parse(_catF):null,Page=_page,PageSize=15};
    var r=await ProductSvc.GetAllAsync(f);
    _products=r?.Items??new(); _total=r?.TotalCount??0; _totalPages=r?.TotalPages??1;
    _loading=false;
  }

  async Task GoPage(int p){_page=p;await Load();}

  void OpenCreate(){_editId=null;_pName=_pNameAr=_pDesc=_pSlug=_pSku=_pMainImg=_pImgs="";_pPrice=0;_pDiscount=0;_pStock=0;_pCatId="";_pFeatured=false;_pActive=true;_mErr="";_showModal=true;}

  void OpenEdit(ProductDto p)
  {
    _editId=p.Id;_pName=p.Name;_pNameAr=p.NameAr;_pDesc=p.Description;_pSlug=p.Slug;_pSku=p.SKU;
    _pPrice=p.Price;_pDiscount=p.DiscountPrice??0;_pStock=p.StockQuantity;_pCatId=p.Category?.Id.ToString()??"";
    _pFeatured=p.IsFeatured;_pActive=p.IsActive;_pMainImg=p.MainImageUrl;
    _pImgs=string.Join("\n",p.Images.Select(i=>i.Url));_mErr="";_showModal=true;
  }

  async Task Save()
  {
    if(string.IsNullOrWhiteSpace(_pName)||_pPrice<=0||string.IsNullOrEmpty(_pCatId)){_mErr="Fill all required fields.";return;}
    _saving=true;
    var imgs=_pImgs.Split('\n',StringSplitOptions.RemoveEmptyEntries|StringSplitOptions.TrimEntries).ToList();
    var dto=new{name=_pName,nameAr=_pNameAr,description=_pDesc,descriptionAr="",slug=_pSlug,sku=_pSku,price=_pPrice,discountPrice=_pDiscount>0?(decimal?)_pDiscount:null,stockQuantity=_pStock,categoryId=Guid.Parse(_pCatId),isFeatured=_pFeatured,isActive=_pActive,mainImageUrl=_pMainImg,imageUrls=imgs};
    ApiResult<ProductDto>? r;
    if(_editId.HasValue) r=await ProductSvc.UpdateAsync(_editId.Value,dto);
    else r=await ProductSvc.CreateAsync(dto);
    if(r?.Success==true){Toast.Success(_editId.HasValue?"Product updated!":"Product created!");_showModal=false;await Load();}
    else _mErr=r?.Message??"Failed.";
    _saving=false;
  }

  async Task Delete()
  {
    if(_delTarget is null) return;
    if(await ProductSvc.DeleteAsync(_delTarget.Id)){Toast.Success("Product deleted.");_delTarget=null;await Load();}
    else{Toast.Error("Failed.");_delTarget=null;}
  }
}
