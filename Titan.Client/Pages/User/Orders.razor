@page "/orders"
@using Titan.Client.Services.Apibase
@using Titan.Client.Services.AppServices
@using Titan.Client.Services.Models
@inject OrderService  Orders
@inject AuthService   Auth
@inject NavigationManager Nav

<PageTitle>My Orders — TITAN</PageTitle>

<div class="main-content" style="padding-top:92px;padding-bottom:60px">
  <div class="container">
    <h1 style="font-size:2rem;margin-bottom:32px">My Orders</h1>

    @if (_loading)
    {
      <div style="text-align:center;padding:60px"><i class="fas fa-spinner fa-spin" style="font-size:2rem;color:var(--gold)"></i></div>
    }
    else if (!_orders.Any())
    {
      <div class="card" style="text-align:center;padding:80px">
        <i class="fas fa-box-open" style="font-size:3.5rem;color:var(--gold);opacity:.25;margin-bottom:22px;display:block"></i>
        <h3 style="margin-bottom:10px">No orders yet</h3>
        <p style="color:var(--silver-dim);margin-bottom:26px">Start shopping and your orders will appear here.</p>
        <a href="/shop" class="btn btn-gold"><i class="fas fa-shopping-bag"></i> Shop Now</a>
      </div>
    }
    else
    {
      <div style="display:flex;flex-direction:column;gap:14px">
        @foreach (var o in _orders)
        {
          <div class="card card-hover" style="cursor:pointer" @onclick="() => Nav.NavigateTo($\"/orders/{o.Id}\")">
            <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:12px">
              <div>
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:6px">
                  <span style="color:var(--gold);font-weight:700;font-size:1rem">@o.OrderNumber</span>
                  <span class="badge @StatusBadge(o.Status)">@o.Status</span>
                </div>
                <p style="color:var(--silver-dim);font-size:.82rem;margin-bottom:3px">
                  <i class="fas fa-calendar" style="margin-right:6px"></i>@o.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                </p>
                <p style="color:var(--silver-dim);font-size:.82rem">
                  <i class="fas fa-box" style="margin-right:6px"></i>@o.Items.Count item(s)
                </p>
              </div>
              <div style="text-align:right">
                <p style="color:var(--gold);font-size:1.25rem;font-weight:700;margin-bottom:8px">$@o.TotalAmount.ToString("F2")</p>
                <span class="btn btn-outline-gold btn-sm">View <i class="fas fa-chevron-right"></i></span>
              </div>
            </div>
            <div style="display:flex;gap:7px;margin-top:14px;padding-top:14px;border-top:1px solid var(--black-border);flex-wrap:wrap">
              @foreach (var item in o.Items.Take(5))
              {
                <img src="@item.ProductImageUrl" title="@item.ProductName"
                     style="width:44px;height:56px;object-fit:cover;border-radius:4px;border:1px solid var(--black-border)" />
              }
              @if (o.Items.Count > 5)
              {
                <div style="width:44px;height:56px;border-radius:4px;border:1px solid var(--black-border);background:var(--black);display:flex;align-items:center;justify-content:center;color:var(--silver-dim);font-size:.78rem">
                  +@(o.Items.Count-5)
                </div>
              }
            </div>
          </div>
        }
      </div>

      @if (_totalPages > 1)
      {
        <div style="display:flex;gap:7px;justify-content:center;margin-top:36px">
          @for (int i = 1; i <= _totalPages; i++)
          { var pg=i; <button class="page-btn @(_page==pg?"active":"")" @onclick="()=>GoPage(pg)">@pg</button> }
        </div>
      }
    }
  </div>
</div>

<style>
  .page-btn{width:38px;height:38px;border-radius:var(--r);border:1px solid var(--black-border);background:var(--black-card);color:var(--silver);cursor:pointer;transition:var(--tr);display:flex;align-items:center;justify-content:center;font-size:.85rem}
  .page-btn:hover,.page-btn.active{border-color:var(--gold);color:var(--gold);background:rgba(212,175,55,.08)}
</style>

@code {
  List<OrderDto> _orders = new();
  bool _loading=true;
  int _page=1,_totalPages=1;

  protected override async Task OnInitializedAsync()
  {
    if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
    await Load();
  }

  async Task Load()
  {
    _loading=true;
    var r = await Orders.GetMyOrdersAsync(_page,10);
    _orders=r?.Items??new(); _totalPages=r?.TotalPages??1;
    _loading=false;
  }

  async Task GoPage(int p) { _page=p; await Load(); }

  static string StatusBadge(OrderStatus s) => s switch
  {
    OrderStatus.Delivered => "badge-success",
    OrderStatus.Cancelled or OrderStatus.Failed => "badge-danger",
    OrderStatus.Shipped or OrderStatus.OutForDelivery => "badge-info",
    _ => "badge-warning"
  };
}
