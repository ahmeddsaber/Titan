@page "/cart"
@using Titan.Client.Services.Apibase
@using Titan.Client.Services.AppServices
@using Titan.Client.Services.Models
@inject CartService CartSvc
@inject AuthService Auth
@inject ToastService Toast
@inject NavigationManager Nav

<PageTitle>Cart — TITAN</PageTitle>

<div class="main-content" style="padding-top:92px;padding-bottom:60px">
    <div class="container">
        <h1 style="font-size:2rem;margin-bottom:32px">Shopping Cart</h1>

        @if (_loading)
        {
            <div style="text-align:center;padding:60px"><i class="fas fa-spinner fa-spin" style="font-size:2rem;color:var(--gold)"></i></div>
        }
        else if (!CartSvc.Current?.Items.Any() ?? true)
        {
            <div class="card" style="text-align:center;padding:80px">
                <i class="fas fa-shopping-bag" style="font-size:3.5rem;color:var(--gold);opacity:.25;margin-bottom:22px;display:block"></i>
                <h3 style="margin-bottom:10px">Your cart is empty</h3>
                <p style="color:var(--silver-dim);margin-bottom:26px">Discover our latest collection.</p>
                <a href="/shop" class="btn btn-gold"><i class="fas fa-tshirt"></i> Shop Now</a>
            </div>
        }
        else
        {
            <div style="display:grid;grid-template-columns:1fr 360px;gap:36px;align-items:start">

                <!-- ITEMS -->
                <div style="display:flex;flex-direction:column;gap:14px">
                    @foreach (var item in CartSvc.Current!.Items)
                    {
                        <div class="card" style="display:flex;gap:16px;padding:18px">
                            <a href="/product/@item.ProductSlug">
                                <img src="@item.ProductImageUrl" alt="@item.ProductName"
                                     style="width:78px;height:98px;object-fit:cover;border-radius:8px;border:1px solid var(--black-border)" />
                            </a>
                            <div style="flex:1;min-width:0">
                                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px;margin-bottom:5px">
                                    <a href="/product/@item.ProductSlug" style="color:var(--white);text-decoration:none;font-weight:600;font-size:.95rem">@item.ProductName</a>
                                    <button @onclick="() => Remove(item)" style="background:none;border:none;color:var(--danger);cursor:pointer;font-size:.95rem;flex-shrink:0">
                                        <i class="fas fa-times"></i>
                                    </button>
                                </div>
                                @if (!string.IsNullOrEmpty(item.VariantInfo))
                                {
                                    <p style="color:var(--silver-dim);font-size:.78rem;margin-bottom:5px">@item.VariantInfo</p>
                                }
                                <p style="color:var(--gold);font-weight:700;margin-bottom:12px">$@item.UnitPrice.ToString("F2")</p>

                                <div style="display:flex;align-items:center;justify-content:space-between">
                                    <div style="display:flex;align-items:center;border:1px solid var(--black-border);border-radius:var(--r);overflow:hidden">
                                        <button @onclick="() => Decr(item)" disabled="@_busy" style="width:34px;height:34px;background:var(--black);border:none;color:var(--silver);cursor:pointer;font-size:1rem;transition:var(--tr)">−</button>
                                        <span style="padding:0 14px;color:var(--white);font-weight:700;min-width:40px;text-align:center">@item.Quantity</span>
                                        <button @onclick="() => Incr(item)" disabled="@(_busy || item.Quantity >= item.StockQuantity)" style="width:34px;height:34px;background:var(--black);border:none;color:var(--silver);cursor:pointer;font-size:1rem;transition:var(--tr)">+</button>
                                    </div>
                                    <span style="color:var(--gold);font-weight:700;font-size:1.05rem">$@item.TotalPrice.ToString("F2")</span>
                                </div>
                            </div>
                        </div>
                    }

                    <div style="display:flex;justify-content:space-between;margin-top:6px;flex-wrap:wrap;gap:10px">
                        <button class="btn btn-outline-silver btn-sm" @onclick="Clear"><i class="fas fa-trash"></i> Clear Cart</button>
                        <a href="/shop" class="btn btn-outline-gold btn-sm"><i class="fas fa-arrow-left"></i> Continue Shopping</a>
                    </div>
                </div>

                <!-- SUMMARY -->
                <div class="card" style="position:sticky;top:88px">
                    <h3 style="font-size:.75rem;letter-spacing:4px;text-transform:uppercase;color:var(--gold);margin-bottom:18px">Order Summary</h3>

                    <div style="display:flex;gap:8px;margin-bottom:16px">
                        <input type="text" class="form-control" placeholder="Coupon code" @bind="_coupon" style="flex:1;font-size:.85rem" />
                        <button class="btn btn-outline-gold btn-sm" @onclick="ApplyCoupon" disabled="@_applying">
                            @if (_applying)
                            {
                                <i class="fas fa-spinner fa-spin"></i>
                            }
                            else
                            {

                                <span>Apply</span>
                            }
                        </button>
                    </div>

                    @if (!string.IsNullOrEmpty(_couponMsg))
                    {
                        <div style="padding:9px 12px;border-radius:6px;margin-bottom:14px;font-size:.82rem;background:@(_couponOk ? "rgba(56,161,105,.1)" : "rgba(229,62,62,.1)");color:@(_couponOk ? "#68D391" : "#FC8181");border:1px solid @(_couponOk ? "var(--success)" : "var(--danger)")">
                            @_couponMsg
                        </div>
                    }

                    <div style="display:flex;flex-direction:column;gap:9px;font-size:.86rem;margin-bottom:18px">
                        <div style="display:flex;justify-content:space-between;color:var(--silver-dim)">
                            <span>Subtotal (@CartSvc.Current!.TotalItems items)</span>
                            <span>$@CartSvc.Current.SubTotal.ToString("F2")</span>
                        </div>
                        @if (CartSvc.Current.DiscountAmount > 0)
                        {
                            <div style="display:flex;justify-content:space-between;color:var(--success)">
                                <span>Discount (@CartSvc.Current.AppliedCouponCode)</span>
                                <span>-$@CartSvc.Current.DiscountAmount.ToString("F2")</span>
                            </div>
                        }
                        <div style="display:flex;justify-content:space-between;color:var(--silver-dim)">
                            <span>Shipping</span>
                            <span>@(CartSvc.Current.ShippingCost == 0 ? "🎉 FREE" : "$" + CartSvc.Current.ShippingCost.ToString("F2"))</span>
                        </div>
                        <hr class="divider" style="margin:4px 0" />
                        <div style="display:flex;justify-content:space-between;font-size:1.08rem;font-weight:700;color:var(--white)">
                            <span>Total</span>
                            <span style="color:var(--gold)">$@CartSvc.Current.TotalAmount.ToString("F2")</span>
                        </div>
                    </div>

                    @if (CartSvc.Current.ShippingCost > 0)
                    {
                        <div style="padding:10px;background:rgba(212,175,55,.06);border:1px solid rgba(212,175,55,.15);border-radius:6px;font-size:.78rem;color:var(--silver-dim);margin-bottom:14px">
                            <i class="fas fa-truck" style="color:var(--gold)"></i>
                            Add <strong style="color:var(--gold)">$@((500 - CartSvc.Current.SubTotal).ToString("F2"))</strong> more for <strong style="color:var(--gold)">FREE shipping!</strong>
                        </div>
                    }

                    <a href="/checkout" class="btn btn-gold btn-block btn-lg"><i class="fas fa-lock"></i> Checkout</a>
                    <p style="text-align:center;font-size:.72rem;color:var(--silver-dim);margin-top:9px"><i class="fas fa-shield-alt"></i> Secure SSL checkout</p>
                </div>
            </div>
        }
    </div>
</div>

@code {
    bool _loading = true, _busy, _applying, _couponOk;
    string _coupon = "", _couponMsg = "";

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        await CartSvc.LoadAsync(); _loading = false;
    }

    async Task Decr(CartItemDto i) { _busy = true; await CartSvc.UpdateQtyAsync(i.Id, i.Quantity - 1); _busy = false; }
    async Task Incr(CartItemDto i) { _busy = true; await CartSvc.UpdateQtyAsync(i.Id, i.Quantity + 1); _busy = false; }
    async Task Remove(CartItemDto i) { await CartSvc.RemoveAsync(i.Id); Toast.Info($"{i.ProductName} removed."); }
    async Task Clear() { await CartSvc.ClearAsync(); Toast.Info("Cart cleared."); }

    async Task ApplyCoupon()
    {
        if (string.IsNullOrWhiteSpace(_coupon)) return;
        _applying = true;
        if (await CartSvc.ApplyCouponAsync(_coupon)) { _couponOk = true; _couponMsg = "✓ Coupon applied!"; }
        else { _couponOk = false; _couponMsg = "Invalid or expired coupon."; }
        _applying = false;
    }
}
