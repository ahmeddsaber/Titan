@using Microsoft.AspNetCore.Components.Routing

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(Titan.Client.Shared.MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="h1" />
    </Found>
    <NotFound>
        <PageTitle>404 — TITAN</PageTitle>
        <div class="not-found-page">
            <div class="brand-font" style="font-size:9rem;color:var(--gold);opacity:.25;line-height:1">404</div>
            <h2 style="margin-bottom:12px">Page Not Found</h2>
            <p style="color:var(--silver-dim);margin-bottom:32px">This territory is uncharted, Titan.</p>
            <a href="/" class="btn btn-gold">Return Home</a>
        </div>
    </NotFound>
</Router>
