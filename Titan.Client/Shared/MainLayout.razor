@using Titan.Client.Services.Apibase
@using Titan.Client.Services.AppServices
@using Titan.Client.Services.Models
@inherits LayoutComponentBase
@inject AuthService      Auth
@inject CartService      Cart
@inject NotificationService Notifs
@inject SignalRService   SignalR
@inject ToastService     Toast
@inject IJSRuntime       JS
@inject NavigationManager Nav
@implements IAsyncDisposable

<TitanNavbar />
<TitanCartDrawer />
<ToastContainer />

<main class="main-content">@Body</main>

<TitanFooter />

@code {
    protected override async Task OnInitializedAsync()
    {
        await Auth.InitAsync();
        Auth.StateChanged  += Refresh;
        Cart.Changed       += Refresh;
        Toast.Changed      += Refresh;
        Notifs.Changed     += Refresh;

        if (Auth.IsAuthenticated)
        {
            await Cart.LoadAsync();
            await Notifs.LoadAsync();
            await ConnectHubAsync();
        }
    }

    private async Task ConnectHubAsync()
    {
        var token = await Auth.GetAccessTokenAsync();
        if (string.IsNullOrEmpty(token)) return;
        SignalR.OnNotification += HandleNotif;
        SignalR.OnOrderUpdate  += HandleOrder;
        await SignalR.ConnectAsync(Nav.BaseUri, token);
    }

    private void HandleNotif(NotificationDto n)
    { Notifs.PushRealTime(n); Toast.Info(n.Title); InvokeAsync(StateHasChanged); }

    private void HandleOrder(OrderDto o)
    { Toast.Info($"Order {o.OrderNumber} → {o.Status}"); InvokeAsync(StateHasChanged); }

    protected override async Task OnAfterRenderAsync(bool first)
    { if (first) try { await JS.InvokeVoidAsync("TitanJS.hideSplash"); } catch { } }

    private void Refresh() => InvokeAsync(StateHasChanged);

    public async ValueTask DisposeAsync()
    {
        Auth.StateChanged  -= Refresh;
        Cart.Changed       -= Refresh;
        Toast.Changed      -= Refresh;
        Notifs.Changed     -= Refresh;
        SignalR.OnNotification -= HandleNotif;
        SignalR.OnOrderUpdate  -= HandleOrder;
        await SignalR.DisposeAsync();
    }
}
