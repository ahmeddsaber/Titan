<aside class="admin-sidebar">
    <div class="sidebar-header">
        <h2 style="color: var(--gold); font-family: 'Montserrat', sans-serif; font-weight: 800; letter-spacing: 2px;">TITAN</h2>
        <p style="font-size: 0.7rem; color: var(--silver-dim); text-transform: uppercase;">Admin Panel</p>
    </div>

    <nav class="sidebar-nav">
        <a href="/admin" class="nav-item @(Active == "dashboard" ? "active" : "")">
            <i class="fas fa-th-large"></i>
            <span>Dashboard</span>
        </a>
        <a href="/admin/products" class="nav-item @(Active == "products" ? "active" : "")">
            <i class="fas fa-box"></i>
            <span>Products</span>
        </a>
        <a href="/admin/categories" class="nav-item @(Active == "categories" ? "active" : "")">
            <i class="fas fa-tags"></i>
            <span>Categories</span>
        </a>
        <a href="/admin/orders" class="nav-item @(Active == "orders" ? "active" : "")">
            <i class="fas fa-shopping-bag"></i>
            <span>Orders</span>
        </a>
        <a href="/admin/users" class="nav-item @(Active == "users" ? "active" : "")">
            <i class="fas fa-users"></i>
            <span>Users</span>
        </a>
        <a href="/admin/coupons" class="nav-item @(Active == "coupons" ? "active" : "")">
            <i class="fas fa-ticket-alt"></i>
            <span>Coupons</span>
        </a>
        <a href="/admin/logs" class="nav-item @(Active == "logs" ? "active" : "")">
            <i class="fas fa-history"></i>
            <span>Logs</span>
        </a>
    </nav>

    <div class="sidebar-footer">
        <a href="/" class="nav-item">
            <i class="fas fa-external-link-alt"></i>
            <span>Back to Shop</span>
        </a>
    </div>
</aside>

<style>
    .admin-sidebar {
        width: 260px;
        background: var(--black-card);
        border-right: 1px solid var(--black-border);
        height: calc(100vh - 90px);
        position: sticky;
        top: 90px;
        display: flex;
        flex-direction: column;
        padding: 20px 0;
    }

    .sidebar-header {
        padding: 0 24px 24px;
        border-bottom: 1px solid var(--black-border);
        margin-bottom: 20px;
    }

    .sidebar-nav {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding: 0 12px;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        color: var(--silver-dim);
        text-decoration: none;
        border-radius: var(--r);
        transition: all 0.2s;
        font-size: 0.9rem;
        font-weight: 500;
    }

    .nav-item:hover {
        background: rgba(212, 175, 55, 0.05);
        color: var(--white);
    }

    .nav-item.active {
        background: linear-gradient(90deg, rgba(212, 175, 55, 0.15), transparent);
        color: var(--gold);
        border-left: 3px solid var(--gold);
    }

    .nav-item i {
        width: 20px;
        text-align: center;
        font-size: 1.1rem;
    }

    .sidebar-footer {
        padding: 20px 12px 0;
        border-top: 1px solid var(--black-border);
    }
</style>

@code {
    [Parameter] public string Active { get; set; } = "";
}
