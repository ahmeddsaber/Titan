@using Titan.Client.Services.AppServices
@* ── ToastContainer ── *@
@inject ToastService Toast

<div class="toast-wrap">
    @foreach (var t in Toast.Items)
    {
        <div class="toast-item @t.Type">
            <i class="fas @(t.Type=="success"?"fa-check-circle":t.Type=="error"?"fa-times-circle":"fa-info-circle")"
               style="color:@(t.Type=="success"?"var(--success)":t.Type=="error"?"var(--danger)":"var(--gold)")"></i>
            <span>@t.Message</span>
        </div>
    }
</div>

<style>
    .toast-wrap {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 10px;
        pointer-events: none
    }

    .toast-item {
        background: var(--black-card);
        border: 1px solid var(--black-border);
        border-radius: var(--r);
        padding: 13px 18px;
        display: flex;
        align-items: center;
        gap: 11px;
        min-width: 260px;
        max-width: 360px;
        box-shadow: var(--shadow);
        animation: slideIn .3s ease;
        font-size: .88rem;
        color: var(--white);
        pointer-events: all
    }

        .toast-item.success {
            border-left: 3px solid var(--success)
        }

        .toast-item.error {
            border-left: 3px solid var(--danger)
        }

        .toast-item.info {
            border-left: 3px solid var(--gold)
        }

        .toast-item.warning {
            border-left: 3px solid var(--warning)
        }
    @keyframes slideIn {
        from {
            transform: translateX(110%);
            opacity: 0
        }

    to {
        transform: translateX(0);
        opacity: 1
    }

    }
</style>

@code { }
