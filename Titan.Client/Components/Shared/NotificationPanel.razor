@using Titan.Client.Services.AppServices
@inject NotificationService Notifs

<div class="notif-panel" @onclick:stopPropagation>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:14px 16px;border-bottom:1px solid var(--black-border)">
        <h4 style="margin:0;font-size:.9rem">Notifications</h4>
        <button @onclick="Notifs.MarkAllReadAsync"
                style="background:none;border:none;color:var(--gold);cursor:pointer;font-size:.78rem;font-weight:600">
            Mark all read
        </button>
    </div>

    <div style="max-height:380px;overflow-y:auto">
        @if (!Notifs.Items.Any())
        {
            <div style="text-align:center;padding:40px;color:var(--silver-dim)">
                <i class="fas fa-bell-slash" style="font-size:1.8rem;opacity:.25;margin-bottom:10px;display:block"></i>
                No notifications
            </div>
        }
        @foreach (var n in Notifs.Items.Take(15))
        {
            <div class="notif-item @(n.IsRead ? "" : "unread")" @onclick="() => Notifs.MarkReadAsync(n.Id)">
                <div style="width:34px;height:34px;border-radius:50%;background:rgba(212,175,55,.1);color:var(--gold);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:.8rem">
                    <i class="@(n.IconClass ?? "fas fa-bell")"></i>
                </div>
                <div style="flex:1;min-width:0">
                    <p style="font-weight:@(n.IsRead ? "500" : "700");color:var(--white);font-size:.83rem;margin-bottom:2px">@n.Title</p>
                    <p style="color:var(--silver-dim);font-size:.78rem;line-height:1.4;margin-bottom:3px">@n.Message</p>
                    <p style="color:var(--silver-dim);font-size:.72rem">@Rel(n.CreatedAt)</p>
                </div>
                @if (!n.IsRead)
                {
                    <div style="width:7px;height:7px;border-radius:50%;background:var(--gold);flex-shrink:0;margin-top:5px"></div>
                }
            </div>
        }
    </div>

    <div style="padding:10px;text-align:center;border-top:1px solid var(--black-border)">
        <a href="/notifications" style="color:var(--gold);font-size:.82rem;text-decoration:none" @onclick="OnClose">View all</a>
    </div>
</div>

@code {
    [Parameter] public EventCallback OnClose { get; set; }

    static string Rel(DateTime d)
    {
        var diff = DateTime.UtcNow - d;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        return $"{(int)diff.TotalDays}d ago";
    }
}
